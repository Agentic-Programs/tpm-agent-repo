# Secrets — never commit
auth/.env
.mcp.json
webapp/backend/.env
webapp/frontend/.env

# Runtime outputs — personal/dated, not source
output/**/*.md
output/**/*.xwiki
output/**/history.json
!output/.gitkeep

# Program/stakeholder data — personal, not source
webapp/backend/data/*.json
!webapp/backend/data/.gitkeep

# Scratch space for anything with real data pasted in for debugging
scratch/

# Node
node_modules/
webapp/frontend/dist/

# OS
.DS_Store
