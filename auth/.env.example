# Copy this file to auth/.env and fill in what you actually have.
# You don't need every integration to start — the daily-focus-digest
# skill still works with just Slack + ms365, for example.
#
# Several integrations below (Atlassian, ms365) authenticate via a
# browser/device-code login on first use instead of a token you paste in
# here — nothing to fill in for those beyond an optional tenant restriction.
#
# NEVER commit auth/.env. It's already in .gitignore — don't remove it.

# ---- GitHub (pr-review-digest) ----
# Fine-grained PAT, scoped to specific repos, read-only.
# https://github.com/settings/personal-access-tokens/new
GITHUB_PAT=

# ---- Slack (daily-focus-digest, meeting-prep) ----
# Bot token from a Slack app you create at api.slack.com/apps.
# Requires workspace admin approval on most corporate workspaces.
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ---- Microsoft 365 / Outlook / Calendar / SharePoint / cloud Excel
# ---- (daily-focus-digest, meeting-prep, risk-action-tracker) ----
# No app registration needed — first run opens a device-code login using
# the ms365 server's own pre-registered Microsoft app. This var is
# optional, only set it to restrict login to a specific org tenant.
MS365_MCP_TENANT_ID=

# ---- Atlassian: Jira + Confluence
# ---- (risk-action-tracker, weekly-status-report, meeting-prep, daily-focus-digest) ----
# No token needed for normal use — first run opens a browser OAuth login
# to your Atlassian Cloud site via the mcp-remote proxy, which caches the
# session. Nothing to fill in here unless you later set up headless/CI
# auth with an API token (see auth/AUTH.md).

# ---- Local Excel / Word (risk-action-tracker export, weekly-status-report export) ----
# No auth — these run entirely against local files. Requires `uv`/`uvx`
# installed (see mcp/README.md), not a credential.

# ---- Internal wiki bridge (see scripts/README.md) ----
# Only relevant if a future org's internal wiki has no MCP server of its
# own — unlike Confluence above, which is already wired.
# Path to an exported session credential, NOT the credential itself.
# Never put a raw session cookie or token directly in this file.
INTERNAL_WIKI_BASE_URL=
INTERNAL_AUTH_CREDENTIAL_PATH=

# ---- Anthropic ----
# Only needed if you're calling the API directly outside the `claude` CLI's
# built-in auth (e.g. a custom script in scripts/).
ANTHROPIC_API_KEY=
