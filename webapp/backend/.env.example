# Copy to backend/.env
PORT=8787

# true = every skill returns realistic canned data instantly, no MCP
# servers or credentials required. This is the default and what makes
# `npm run dev` work with zero setup.
#
# false = skills call mcpClient.js, which expects the servers in
# ../../mcp/.mcp.json to be installed and auth'd per ../../auth/AUTH.md.
# Flip this once you've wired at least one real integration end to end —
# see each skill's TODO comment in src/skills/ for the swap point.
MOCK_MODE=true
